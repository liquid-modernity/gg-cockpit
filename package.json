    "ci": "npm run qa && npm run test:e2e",
    "qa:source-of-truth": "node qa/source-of-truth-guard.mjs",
    "qa:registry": "node qa/registry-hardcode-guard.mjs",
    "qa:css": "node qa/css-namespace-guard.mjs",
