  "type": "module",
  "scripts": {
    "qa": "node qa/architecture-guard.mjs && node qa/frontend-contract-guard.mjs && node qa/naming-guard.mjs && node qa/source-of-truth-guard.mjs && node qa/registry-hardcode-guard.mjs && node qa/css-namespace-guard.mjs && node qa/generated-artifact-guard.mjs && node qa/worker-secret-guard.mjs",
